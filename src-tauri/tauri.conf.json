{
  "productName": "Messenger X",
  "version": "1.2.3",
  "identifier": "com.lasakondrej.messengerx",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": [
      "dmg",
      "app",
      "nsis",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "SocialNetworking",
    "copyright": "© 2026 Messenger X Contributors",
    "shortDescription": "Cross-platform Facebook Messenger desktop client",
    "longDescription": "Messenger X is a lightweight, cross-platform desktop client for Facebook Messenger built with Tauri. It provides native desktop notifications, system tray integration, offline detection, and a clean WebView-powered interface on macOS, Windows, and Linux.",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "hardenedRuntime": true,
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      },
      "entitlements": null,
      "signingIdentity": "-",
      "providerShortName": null,
      "files": {}
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "allowDowngrades": true,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false
      },
      "wix": null,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM1MjE4NDRGM0MzODcyRkUKUldUK2NqZzhUNFFoeFdsU3ZYK1lDd0lzRURwemZ1ODhDNGpXMDk3dzkwQjFTQU1XQmEvUnhLa24K",
      "endpoints": [
        "https://github.com/jimicze/fb-messanger-crossplatform/releases/latest/download/latest.json"
      ]
    }
  }
}
