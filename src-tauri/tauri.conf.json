{
  "productName": "Messenger X",
  "version": "0.1.3",
  "identifier": "com.lasakondrej.messengerx",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",

    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],

    "category": "SocialNetworking",
    "copyright": "© 2026 Messenger X Contributors",
    "shortDescription": "Cross-platform Facebook Messenger desktop client",
    "longDescription": "Messenger X is a lightweight, cross-platform desktop client for Facebook Messenger built with Tauri. It provides native desktop notifications, system tray integration, offline detection, and a clean WebView-powered interface on macOS, Windows, and Linux.",

    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libappindicator3-1",
          "librsvg2-2",
          "libglib2.0-0",
          "libssl3",
          "libdbus-1-3"
        ],
        "files": {}
      },
      "appimage": {
        "bundleMediaFramework": false,
        "files": {}
      },
      "rpm": {
        "epoch": 0,
        "files": {},
        "release": "1",
        "depends": [
          "webkit2gtk4.1",
          "libappindicator-gtk3",
          "librsvg2",
          "glib2",
          "openssl",
          "dbus"
        ]
      }
    },

    "macOS": {
      "minimumSystemVersion": "10.13",
      "hardenedRuntime": true,
      "dmg": {
        "windowSize": { "width": 660, "height": 400 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      },
      "entitlements": null,
      "signingIdentity": null,
      "providerShortName": null,
      "files": {}
    },

    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "allowDowngrades": true,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "wix": null,
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "signCommand": null,
      "timestampUrl": null,
      "tsp": false
    }
  }
}
